<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- WARNING: The scriptProcessor path must match the exact Python installation path on your host's Windows server. -->
      <!-- You MUST ask your hosting provider what the correct path to Python and wfastcgi.py is. -->
      <add name="Python FastCGI" 
           path="*" 
           verb="*" 
           modules="FastCgiModule" 
           scriptProcessor="C:\Python39\python.exe|C:\Python39\Lib\site-packages\wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
  </system.webServer>

  <appSettings>
    <!-- Required settings for Django -->
    <add key="WSGI_HANDLER" value="django.core.wsgi.get_wsgi_application()" />
    <!-- WARNING: Update this to match your absolute path if different. -->
    <add key="PYTHONPATH" value="C:\Inetpub\vhosts\abumonyaagency.com\httpdocs" />
    <!-- Django settings module -->
    <add key="DJANGO_SETTINGS_MODULE" value="abo.settings" />
  </appSettings>
</configuration>
